    <author>malagege</author>
    <guid>https://malagege.github.io/blog/posts/%E6%8E%92%E6%9F%A5%E4%B8%AD%E8%8F%AF%E9%9B%BB%E4%BF%A1%E5%85%89%E4%B8%96%E4%BB%A3%E9%80%A3%E4%B8%8D%E5%88%B0%E7%89%B9%E5%AE%9A%E7%B6%B2%E7%AB%99%E5%95%8F%E9%A1%8C%E8%88%87%E5%A0%B1%E4%BF%AE%E6%96%B9%E5%BC%8F/</guid>
